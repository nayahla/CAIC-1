{% extends "layouts/main" %}

{% set homePage = craft.entries.section('homepage').one() %}
{% set getInvolvedPage = craft.entries.section('getInvolvedPage').one() %}
{% set page = getInvolvedPage ?? homePage %}
{% set getInvolvedHeroAsset = page and page.getInvolvedHeroImage ? page.getInvolvedHeroImage.one() : null %}
{% set fallbackHeroAsset = homePage and homePage.heroBackground ? homePage.heroBackground.one() : null %}
{% set getInvolvedHeroImageUrl = getInvolvedHeroAsset ? getInvolvedHeroAsset.url : (fallbackHeroAsset ? fallbackHeroAsset.url : '/images/heroback.jpg') %}
{% set getInvolvedHeroEyebrow = page and page.getFieldValue('getInvolvedHeroEyebrow') ? page.getFieldValue('getInvolvedHeroEyebrow') : 'Get Involved' %}
{% set getInvolvedHeroHeading = page and page.getFieldValue('getInvolvedHeroHeading') ? page.getFieldValue('getInvolvedHeroHeading') : 'Get Involved' %}
{% set getInvolvedHeroDescription = page and page.getFieldValue('getInvolvedHeroDescription') ? page.getFieldValue('getInvolvedHeroDescription') : "The Colorado Alcohol Impacts Coalition (CAIC) has officially launched and is now welcoming new partners to join this statewide effort. We invite community leaders, public safety professionals, public health experts, treatment providers, researchers, advocates, and other stakeholders to get involved as we work together to reduce alcohol-related harms across Colorado. By joining CAIC, you will help raise awareness of alcohol's impact on health and safety, amplify community voices, and drive collaborative action toward a healthier, safer Colorado." %}
{% set getInvolvedHeroDescriptionSecondary = page and page.getFieldValue('getInvolvedHeroDescriptionSecondary') ? page.getFieldValue('getInvolvedHeroDescriptionSecondary') : '' %}

{% block body %}
<div class="caic">
  <main class="caic-getInvolvedPage">
    <section class="caic-hero" style="background-image:url('{{ getInvolvedHeroImageUrl }}')">
      <div class="caic-hero__overlay" aria-hidden="true"></div>
      <div class="caic-container caic-hero__inner">
        <div class="caic-hero__content reveal">
          <div class="caic-kickerPill">{{ getInvolvedHeroEyebrow }}</div>
          <h1 class="caic-heroTitle">{{ getInvolvedHeroHeading }}</h1>
          <p class="caic-heroSub">{{ getInvolvedHeroDescription }}</p>
          {% if getInvolvedHeroDescriptionSecondary %}
            <p class="caic-heroSub">{{ getInvolvedHeroDescriptionSecondary }}</p>
          {% endif %}
        </div>
      </div>
    </section>

    <section class="caic-section caic-getInvolvedWays">
      <div class="caic-container">
        <div class="caic-leftHead caic-getInvolvedWays__head">
          <h2 class="caic-h2">{{ page and page.getFieldValue('getInvolvedWaysHeading') ? page.getFieldValue('getInvolvedWaysHeading') : 'Ways to Participate' }}</h2>
          <p class="caic-body">{{ page and page.getFieldValue('getInvolvedWaysIntro') ? page.getFieldValue('getInvolvedWaysIntro') : 'Find the path that best suits your commitment level and interest.' }}</p>
        </div>

        <div class="caic-getInvolvedCardGrid">
          <article class="caic-getInvolvedCard caic-grow">
            <h3 class="caic-getInvolvedCard__title">{{ page and page.getFieldValue('getInvolvedCardOneTitle') ? page.getFieldValue('getInvolvedCardOneTitle') : 'Attend Coalition Meetings' }}</h3>
            <p class="caic-getInvolvedCard__text">
              {{ page and page.getFieldValue('getInvolvedCardOneText') ? page.getFieldValue('getInvolvedCardOneText') : 'Our primary coalition meetings are fully open to the public. Join us to hear latest data, discuss policy impacts, and witness collaborative problem-solving in real time.' }}
            </p>
            {% set cardOneLink = page and page.getFieldValue('getInvolvedCardOneLink') ? (page.getFieldValue('getInvolvedCardOneLink').url ?? page.getFieldValue('getInvolvedCardOneLink')) : url('events') %}
            <a class="caic-getInvolvedCard__link" href="{{ cardOneLink }}">{{ page and page.getFieldValue('getInvolvedCardOneLinkLabel') ? page.getFieldValue('getInvolvedCardOneLinkLabel') : 'View Meeting Schedule' }} <span class="caic-linkArrow" aria-hidden="true">&rarr;</span></a>
          </article>

          <article class="caic-getInvolvedCard caic-grow">
            <h3 class="caic-getInvolvedCard__title">{{ page and page.getFieldValue('getInvolvedCardTwoTitle') ? page.getFieldValue('getInvolvedCardTwoTitle') : 'Join a Workgroup' }}</h3>
            <p class="caic-getInvolvedCard__text">
              {{ page and page.getFieldValue('getInvolvedCardTwoText') ? page.getFieldValue('getInvolvedCardTwoText') : 'Dive deeper into specific impact areas. We currently maintain three core workgroups focused on Evidence Synthesis, Public Health Advocacy, and Community Outreach.' }}
            </p>
            {% set cardTwoLink = page and page.getFieldValue('getInvolvedCardTwoLink') ? (page.getFieldValue('getInvolvedCardTwoLink').url ?? page.getFieldValue('getInvolvedCardTwoLink')) : url('workgroups') %}
            <a class="caic-getInvolvedCard__link" href="{{ cardTwoLink }}">{{ page and page.getFieldValue('getInvolvedCardTwoLinkLabel') ? page.getFieldValue('getInvolvedCardTwoLinkLabel') : 'Learn About Workgroups' }} <span class="caic-linkArrow" aria-hidden="true">&rarr;</span></a>
          </article>
        </div>
      </div>
    </section>
  </main>
</div>
{% endblock %}
