{% extends "layouts/main" %}

{% set contactPage = entry ?? craft.entries.section('contactUs').one() %}
{% set contactEmail = contactPage and contactPage.contactEmail ? contactPage.contactEmail|trim : 'info@caic-colorado.org' %}
{% set contactWebsiteHref = contactPage and contactPage.contactWebsiteLink ? (contactPage.contactWebsiteLink.url ?? contactPage.contactWebsiteLink) : siteUrl %}
{% set contactLinkedinHref = contactPage and contactPage.contactLinkedinLink ? (contactPage.contactLinkedinLink.url ?? contactPage.contactLinkedinLink) : '#' %}

{% block body %}
<div class="caic">
  <main class="caic-contactPage">
    <section class="caic-section caic-contactSection">
      <div class="caic-container">
        <div class="caic-contactLayout">
          <div class="caic-contactIntroColumn">
            <div class="caic-contactHero__inner caic-contactHero__inner--inline">
              <p class="caic-contactHero__eyebrow">Get Support</p>
              <h1 class="caic-h1 caic-contactHero__title">Contact Us</h1>
              <div class="caic-contactHero__divider" aria-hidden="true"></div>
            </div>

            <aside class="caic-contactAside">
              <div class="caic-contactAside__intro">
                <p class="caic-contactAside__text">
                  Whether you're a community leader, a healthcare provider, or a concerned citizen, we want to hear from you. Please share any questions or concerns.
                </p>
              </div>

              <a class="caic-contactEmailCard" href="mailto:{{ contactEmail }}">
                <span class="caic-contactEmailCard__icon" aria-hidden="true">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M1.5 6.75A2.25 2.25 0 0 1 3.75 4.5h16.5a2.25 2.25 0 0 1 2.25 2.25v.406l-10.5 5.7-10.5-5.7V6.75Z"/>
                    <path d="M1.5 9.714v7.536A2.25 2.25 0 0 0 3.75 19.5h16.5a2.25 2.25 0 0 0 2.25-2.25V9.714l-9.963 5.408a1.125 1.125 0 0 1-1.074 0L1.5 9.714Z"/>
                  </svg>
                </span>
                <span class="caic-contactEmailCard__copy">
                  <span class="caic-contactEmailCard__label">Email Us</span>
                  <span class="caic-contactEmailCard__value">{{ contactEmail }}</span>
                </span>
              </a>

              <div class="caic-contactSocial">
                <p class="caic-contactSocial__label">Connect With Us</p>
                <div class="caic-contactSocial__row">
                  <a class="caic-contactSocial__link" href="{{ contactWebsiteHref }}" aria-label="Website">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                      <path fill-rule="evenodd" d="M2.25 12c0 5.385 4.365 9.75 9.75 9.75s9.75-4.365 9.75-9.75S17.385 2.25 12 2.25 2.25 6.615 2.25 12ZM12 4.5c.849 0 2.12 1.56 2.788 4.5H9.212C9.88 6.06 11.151 4.5 12 4.5Zm-3.27 6a19.64 19.64 0 0 0 0 3h6.54a19.64 19.64 0 0 0 0-3H8.73Zm6.058 4.5c-.668 2.94-1.94 4.5-2.788 4.5-.849 0-2.12-1.56-2.788-4.5h5.576ZM7.676 15c.2 1.04.49 2.004.858 2.846A7.516 7.516 0 0 1 4.77 15h2.906Zm-2.906-6a7.516 7.516 0 0 1 3.764-2.846A13.76 13.76 0 0 0 7.676 9H4.77Zm11.554 0a13.76 13.76 0 0 0-.858-2.846A7.516 7.516 0 0 1 19.23 9h-2.906Zm2.906 6a7.516 7.516 0 0 1-3.764 2.846c.368-.842.658-1.806.858-2.846h2.906Z" clip-rule="evenodd"/>
                    </svg>
                  </a>
                  <a class="caic-contactSocial__link" href="{{ contactLinkedinHref }}" aria-label="LinkedIn">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                      <path d="M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854zm4.943 12.248V6.169H2.542v7.225zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248-.015-.709-.52-1.248-1.342-1.248S2.4 3.226 2.4 3.934c0 .694.521 1.248 1.327 1.248zm4.908 8.212V9.359c0-.216.016-.432.08-.586.173-.431.568-.878 1.232-.878.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252-1.274 0-1.845.7-2.165 1.193v.025h-.016l.016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225z"/>
                    </svg>
                  </a>
                </div>
              </div>
            </aside>
          </div>

          <article class="caic-contactCard">
            <h2 class="caic-contactCard__title">Send a Message</h2>

            <form class="caic-contactForm" novalidate>
              <div class="caic-contactForm__field">
                <label for="contactFullName">Full Name</label>
                <input id="contactFullName" type="text" name="fullName" placeholder="Enter your full name">
              </div>

              <div class="caic-contactForm__field">
                <label for="contactEmail">Email Address</label>
                <input id="contactEmail" type="email" name="email" placeholder="name@example.com">
              </div>

              <div class="caic-contactForm__field">
                <label for="contactMessage">Message</label>
                <textarea id="contactMessage" name="message" rows="5" placeholder="How can we help?"></textarea>
              </div>

              <button class="caic-contactForm__submit" type="button">Send Message</button>
            </form>
          </article>
        </div>
      </div>
    </section>
  </main>
</div>
{% endblock %}
